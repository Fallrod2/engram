# Anthropic API key — server-side only. Copy this file to .env and fill it in.
# NEVER commit the real key.
ANTHROPIC_API_KEY=

# Postgres connection string. Defaults to the local Supabase stack when unset,
# so you usually don't need to set this in local dev. NEVER commit a cloud
# credential here.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
