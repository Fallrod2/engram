# --- AI providers ------------------------------------------------------------
# Card/quiz generation is now MULTI-PROVIDER, configured in the app at
# Réglages → Intelligence artificielle (Anthropic, OpenRouter, Ollama,
# OpenAI-compatible). Keys entered there are stored server-side, write-only, and
# never shown again. Generation is unavailable (503) only when NO provider is
# usable.
#
# Optional env fallbacks (retro-compat; the app config takes precedence). NEVER
# commit a real key:
#   ANTHROPIC_API_KEY     — Anthropic (also resolves an `ant auth login` profile)
#   OPENROUTER_API_KEY    — OpenRouter
#   OPENAI_API_KEY        — generic OpenAI-compatible endpoints
#   MISTRAL_API_KEY       — Mistral (generation + the dedicated /v1/ocr OCR API)
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# MISTRAL_API_KEY=
#
# Ollama is local, free and needs NO key: if an Ollama server is running
# (default http://localhost:11434), pick it in Réglages and choose an installed
# model — zero cost, fully private.

# Postgres connection string. Defaults to the local Supabase stack when unset,
# so you usually don't need to set this in local dev. NEVER commit a cloud
# credential here.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Timezone. All day/week bucketing (analytics + planning) runs in the process
# timezone; leave unset locally to use the machine's zone. On UTC hosts (e.g.
# Vercel) this MUST be set to the user's zone or the buckets drift by a day.
# See docs/deploy-vercel.md for the full deploy env reference.
# TZ=Europe/Zurich

# --- Auth (Supabase) ---------------------------------------------------------
# Server-side JWT verification. In prod (Vercel) the Vercel×Supabase integration
# injects SUPABASE_URL automatically — do NOT set it here. Locally, leave it
# empty: the application auth gate is then DISABLED (localhost, no exposure).
# SUPABASE_URL=
# Optional, ONLY to test the login against a LOCAL GoTrue (HS256 path):
# SUPABASE_JWT_SECRET=
#
# Test-only auth bypass (like ENGRAM_FAKE_AI). Dev/e2e local only; IGNORED on
# Vercel (VERCEL=1 or NODE_ENV=production). NEVER set this in production.
# ENGRAM_AUTH_DISABLED=1
#
# --- Account CRUD (spec §2, GoTrue Admin API) --------------------------------
# GoTrue service_role key — SERVER ONLY. Enables creating/editing accounts from
# /admin (invite by email or temporary password). Read once by the admin client;
# NEVER exposed in any response or log. On Vercel the Supabase×Vercel integration
# usually injects it — verify before setting. Absent → account creation/edit
# returns a clean 503 (account_mgmt_unavailable); every other feature works.
# NEVER commit a real key.
# SUPABASE_SERVICE_ROLE_KEY=
#
# Trusted public site base URL for the invitation redirect (amendment A9). MUST be
# server-set (never derived from the request Origin). The invite link lands here,
# then the app routes to /set-password. Prod: https://engram.alexabriel.com
# Local dev fallback if unset: http://localhost:5174
# ENGRAM_PUBLIC_SITE_URL=https://engram.alexabriel.com

# --- Multi-user (user_id scoping, spec §2bis) --------------------------------
# When the auth gate is NOT enforced (local dev / e2e bypass), the server poses a
# default identity whose `sub` is this value (fallback: 'dev-user'). After the
# 0004 migration backfills existing rows to Alex's Supabase UID, set this to that
# UID locally so the live dashboard (3001/5173) shows the backfilled data —
# otherwise the default 'dev-user' owns nothing and the dashboard looks empty.
# ENGRAM_DEV_USER_ID=20d58a6e-71c6-4af2-b1d4-143c93970f8b
#
# Admin gate (spec §3): only this user may write AI config / use the backup
# routes. On Vercel set it to Alex's UID. Absent in enforced prod → those routes
# fail-closed (403 for everyone). Under the dev bypass the default identity above
# is treated as the admin, so local dev needs nothing here.
# ENGRAM_ADMIN_USER_ID=20d58a6e-71c6-4af2-b1d4-143c93970f8b
#
# Demo account (spec §4, optional). When set, a login as THIS user wipes+reseeds
# a fresh demo dataset on each new Supabase session. Absent → no demo behaviour
# (current prod). The demo Supabase user is created by Alex, not by the app.
# ENGRAM_DEMO_USER_ID=

# --- Web (client, PUBLIC values) ---------------------------------------------
# The anon key is PUBLIC by design (identifies the project, grants nothing). On
# Vercel these are mapped from SUPABASE_URL / SUPABASE_ANON_KEY by vite.config
# (define). Locally, leave empty (web auth OFF). See apps/web/.env.example.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
