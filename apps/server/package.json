{
  "name": "@engram/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:db": "bun test --preload ./src/test-support/db-preload.ts ./src/db/*.spec.ts ./src/services/*.spec.ts ./src/routes/*.spec.ts ./src/*.spec.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@engram/shared": "workspace:*",
    "@hono/zod-validator": "0.4.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "ts-fsrs": "^5.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.10"
  }
}
