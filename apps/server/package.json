{
  "name": "@engram/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:db": "bun test --preload ./src/test-support/db-preload.ts ./src/db/*.spec.ts ./src/services/*.spec.ts ./src/routes/*.spec.ts ./src/auth/*.spec.ts ./src/http/*.spec.ts ./src/*.spec.ts",
    "test:db:pg": "bun test ./src/db/*.pgtest.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:reset": "bun run src/db/reset.ts && bun run db:migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@engram/shared": "workspace:*",
    "@hono/zod-validator": "0.4.3",
    "@vercel/functions": "^3.7.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "postgres": "^3.4.9",
    "ts-fsrs": "^5.4.1",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.10"
  }
}
